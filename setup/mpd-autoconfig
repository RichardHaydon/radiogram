#!/usr/bin/env python3
"""Auto-configure MPD's audio_output for the currently-attached DAC.

Detects which non-onboard playback card is present (USB DAC, I2S
HAT, whatever) by walking /proc/asound/cards, picks a sensible
hardware mixer on that card, and rewrites the audio_output stanza
in /etc/mpd.conf to match. Idempotent — only touches the file when
the existing stanza would differ from what should be there.

Why this exists: ALSA card names are baked into mpd.conf as
hw:CARD=<name>, and the name comes from the USB device descriptor.
Different DACs report different names (C-Media → "Device",
Realtek → "Audio") and different mixer controls (PCM, Speaker, …).
A DAC swap previously meant manually editing mpd.conf and bouncing
the daemon. This helper makes the swap self-healing on boot.

Designed to run in two contexts:
- At boot via the clockradio-mpd-autoconfig.service systemd unit
  (ordered Before=mpd.service) so MPD starts with a fresh config.
- On hot-plug via the 99-clockradio-audio.rules udev rule fired
  by ACTION=="add|remove" on a USB sound card.

When the config is rewritten and MPD is currently active, the helper
bounces MPD and refreshes the bluealsa-aplay sink route so phone-as-
speaker keeps tracking the new card too. Doing this here (rather than
in the systemd unit's ExecStartPost=) avoids relying on $EXIT_STATUS
which isn't reliably exported across distros.
"""
from __future__ import annotations

import re
import subprocess
import sys
from pathlib import Path


MPD_CONF = Path("/etc/mpd.conf")
BT_HELPER = Path("/usr/local/sbin/clockradio-bt-output")
# Pi onboard / HDMI outputs we deliberately skip — we want to find
# the user-added USB DAC or I2S HAT, not fall back to the 3.5 mm jack
# (clicky, no audible output on the Pi 3) or HDMI (no speakers wired).
ONBOARD_CARDS = ("Headphones", "vc4hdmi", "bcm2835")


def list_playback_cards() -> list[tuple[int, str]]:
    """Returns [(index, name), ...] from /proc/asound/cards. The name
    is what shows up in hw:CARD=<name> (the symbolic short id, e.g.
    'Audio' for the Realtek USB DAC)."""
    cards: list[tuple[int, str]] = []
    try:
        text = Path("/proc/asound/cards").read_text()
    except OSError:
        return cards
    for line in text.splitlines():
        m = re.match(r"\s*(\d+)\s+\[([^\]]+?)\s*\]:", line)
        if m:
            cards.append((int(m.group(1)), m.group(2)))
    return cards


def pick_target_card() -> tuple[int, str] | None:
    """Return the first non-onboard playback card, or None if there
    isn't one. We deliberately don't fall back to the onboard
    Headphones jack — sending audio there would be silently broken on
    a system the user provisioned to use an external DAC."""
    for idx, name in list_playback_cards():
        if any(name == oc or name.startswith(oc) for oc in ONBOARD_CARDS):
            continue
        return idx, name
    return None


def render_block(card: str) -> str:
    """Build the audio_output stanza for `card`.

    mixer_type is "software" rather than "hardware" because cheap USB
    DAC chips (Jieli, C-Media, etc.) typically expose only ~16–32
    discrete hardware mixer buckets — MPD's setvol 1, 2, 3, ... all
    round to the same bucket at the low end, making fine-grained
    bedside-volume control impossible. Software mixer scales PCM in
    the daemon, sends full-scale audio to the DAC, and gives a true
    1% step everywhere. The CPU cost on a Pi 3 is negligible (a few
    multiplies per buffer); the alarm volume ramp also benefits from
    a smoother fade-in. If a card is later swapped in that has a
    truly high-resolution hardware mixer (and someone misses the
    knob-style behaviour), this is the single line to revisit.
    """
    return (
        'audio_output {\n'
        '    type            "alsa"\n'
        '    name            "Clockradio Output"\n'
        f'    device          "hw:CARD={card},DEV=0"\n'
        '    mixer_type      "software"\n'
        '}'
    )


def replace_audio_output(text: str, new_block: str) -> str:
    """Replace the first audio_output { ... } stanza, or append one
    if none exists. The non-greedy [^}]* match is safe because mpd.conf
    blocks don't nest curly braces."""
    pat = re.compile(r"audio_output\s*\{[^}]*\}", re.S)
    if pat.search(text):
        return pat.sub(new_block.replace("\\", "\\\\"), text, count=1)
    return text.rstrip() + "\n\n" + new_block + "\n"


def main() -> int:
    card = pick_target_card()
    if card is None:
        print("mpd-autoconfig: no external playback card present; "
              "leaving mpd.conf alone", file=sys.stderr)
        return 0
    _idx, card_name = card

    try:
        current = MPD_CONF.read_text()
    except FileNotFoundError:
        print(f"mpd-autoconfig: {MPD_CONF} not found", file=sys.stderr)
        return 2

    new_block = render_block(card_name)
    rewritten = replace_audio_output(current, new_block)
    if rewritten == current:
        print(f"mpd-autoconfig: already configured for card='{card_name}'")
        return 0

    tmp = MPD_CONF.with_suffix(".autoconfig.tmp")
    tmp.write_text(rewritten)
    tmp.chmod(0o644)
    tmp.replace(MPD_CONF)
    print(f"mpd-autoconfig: rewrote audio_output for card='{card_name}' "
          "(software mixer)")

    # If MPD is already running (i.e. we got here via hot-plug, not via
    # the Before=mpd.service boot path), queue a restart so it picks up
    # the new device. --no-block is essential: this helper's systemd
    # unit declares Before=mpd.service, so a blocking try-restart from
    # inside the helper deadlocks against its own ordering — systemd
    # waits for the autoconfig unit to finish before starting mpd, but
    # the autoconfig unit is itself blocking on the mpd restart job.
    # --no-block returns immediately and lets systemd dispatch the
    # restart once we exit.
    mpd_active = subprocess.run(
        ["systemctl", "is-active", "--quiet", "mpd"]).returncode == 0
    if mpd_active:
        subprocess.run(
            ["systemctl", "--no-block", "try-restart", "mpd"],
            check=False)
        print("mpd-autoconfig: queued mpd restart")

    # Keep the bluealsa-aplay sink route in sync with MPD's primary
    # output so a paired phone keeps playing to the new card too.
    # The bt helper is installed by the same bootstrap, but be defensive
    # — if it's missing we just skip (BT routing is non-critical).
    if BT_HELPER.exists():
        subprocess.run(
            [str(BT_HELPER), "set-sink-route",
             f"hw:CARD={card_name},DEV=0"],
            check=False)
        print(f"mpd-autoconfig: updated bluealsa route to card='{card_name}'")

    # Exit code 10 retained for backwards compat with any external
    # caller that checks $? — the systemd unit no longer relies on it.
    return 10


if __name__ == "__main__":
    sys.exit(main())
